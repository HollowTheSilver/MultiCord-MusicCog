{
  "$schema": "https://multicord.io/schemas/cog.schema.json",
  "type": "cog",
  "id": "music",
  "name": "Music",
  "description": "Music playback bot with queue management, YouTube support, and voice controls",
  "version": "1.0.0",
  "author": "MultiCord Team",
  "category": "entertainment",
  "tags": ["music", "audio", "youtube", "playback", "queue", "voice"],
  "discord_py_version": ">=2.0.0",
  "python_version": ">=3.9",
  "database_required": false,
  "database_optional": false,
  "files": ["__init__.py", "requirements.txt", "manifest.json", "README.md"],
  "featured": true,
  "changelog": {
    "1.0.0": "Initial release with join, leave, play, pause, resume, stop, skip, queue, nowplaying, volume commands"
  },
  "features": {
    "voice_connect": true,
    "youtube_playback": true,
    "queue_management": true,
    "volume_control": true,
    "pause_resume": true,
    "skip_command": true,
    "nowplaying": true
  },
  "commands": {
    "voice": ["join", "leave"],
    "playback": ["play", "pause", "resume", "stop", "skip"],
    "queue": ["queue", "nowplaying"],
    "controls": ["volume"]
  },
  "permissions": {
    "required": ["send_messages", "embed_links", "connect", "speak"],
    "optional": ["manage_messages"]
  },
  "external_dependencies": {
    "ffmpeg": {
      "required": true,
      "description": "Audio processing and encoding",
      "install_url": "https://ffmpeg.org/download.html"
    },
    "yt-dlp": {
      "required": true,
      "description": "YouTube audio extraction",
      "install_url": "https://github.com/yt-dlp/yt-dlp"
    }
  },
  "compatibility": {
    "multicord_version": ">=3.0.0",
    "platforms": ["windows", "linux", "macos"]
  }
}
